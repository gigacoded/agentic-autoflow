  "convex-backend-dev": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Convex backend development with MCP integration and performance optimization",
    "promptTriggers": {
      "keywords": [
        "convex",
        "backend",
        "query",
        "mutation",
        "action",
        "database",
        "schema",
        "server",
        "bandwidth",
        "performance",
        "optimize",
        "index",
        "slow",
        "expensive",
        "billing",
        "cost",
        "full table scan",
        "collect"
      ],
      "intentPatterns": [
        "(create|write|add|implement).*?(query|mutation|action|function)",
        "(update|modify|change).*?(schema|database|table)",
        "(backend|server).*?(logic|function|api)",
        "convex.*?(function|query|mutation)",
        "(optimize|improve|fix).*(query|performance|bandwidth)",
        "(slow|expensive|costly).*(query|queries)",
        "(add|create|need).*index",
        "(audit|review|check).*(performance|bandwidth|queries)",
        "full.*table.*scan",
        "convex.*(billing|cost|bandwidth)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "convex/**/*.ts",
        "convex/schema.ts",
        "convex/_generated/**/*"
      ],
      "contentPatterns": [
        "import.*convex/server",
        "query\\(",
        "mutation\\(",
        "action\\(",
        "defineSchema",
        "defineTable",
        "\\.collect\\(\\)",
        "\\.filter\\(",
        "\\.withIndex\\("
      ]
    }
  },
