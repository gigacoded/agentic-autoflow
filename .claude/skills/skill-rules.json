{
  "usage-guide": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "medium",
    "description": "Map of this agent infrastructure kit: which skill/tool/loop to use when, where everything lives, how to maintain or install it.",
    "promptTriggers": {
      "keywords": [
        "which skill",
        "usage guide",
        "how does this kit",
        "agent infrastructure",
        "add a skill",
        "new skill",
        "install the kit",
        "setup.sh",
        "skill-rules"
      ],
      "intentPatterns": [
        "(which|what).*?(skill|tool|mcp).*?(use|apply|for)",
        "(add|create|update|edit).*?(skill|hook|rule).*?(kit|infrastructure|claude|codex)",
        "(install|set up|copy).*?(kit|infrastructure|autoflow).*?(project|codebase|repo)",
        "(how|where).*?(skills|hooks|settings).*?(work|configured|live)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/skills/**/*",
        ".codex/skills/**/*",
        ".claude/settings.json",
        ".codex/config.toml"
      ],
      "contentPatterns": []
    }
  },
