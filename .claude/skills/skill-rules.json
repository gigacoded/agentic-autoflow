{
  "convex-backend-dev": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Convex backend development with MCP integration and performance optimization",
    "promptTriggers": {
      "keywords": [
        "convex",
        "backend",
        "query",
        "mutation",
        "action",
        "database",
        "schema",
        "server",
        "bandwidth",
        "performance",
        "optimize",
        "index",
        "slow",
        "expensive",
        "billing",
        "cost",
        "full table scan",
        "collect"
      ],
      "intentPatterns": [
        "(create|write|add|implement).*?(query|mutation|action|function)",
        "(update|modify|change).*?(schema|database|table)",
        "(backend|server).*?(logic|function|api)",
        "convex.*?(function|query|mutation)",
        "(optimize|improve|fix).*(query|performance|bandwidth)",
        "(slow|expensive|costly).*(query|queries)",
        "(add|create|need).*index",
        "(audit|review|check).*(performance|bandwidth|queries)",
        "full.*table.*scan",
        "convex.*(billing|cost|bandwidth)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "convex/**/*.ts",
        "convex/schema.ts",
        "convex/_generated/**/*"
      ],
      "contentPatterns": [
        "import.*convex/server",
        "query\\(",
        "mutation\\(",
        "action\\(",
        "defineSchema",
        "defineTable",
        "\\.collect\\(\\)",
        "\\.filter\\(",
        "\\.withIndex\\("
      ]
    }
  },
  "frontend-dev": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "React, Tailwind CSS, and shadcn/ui frontend patterns (UI/styling). For deep TanStack Start work use tanstack-start-dev.",
    "promptTriggers": {
      "keywords": [
        "component",
        "frontend",
        "ui",
        "page",
        "layout",
        "react",
        "tailwind",
        "style",
        "form",
        "shadcn"
      ],
      "intentPatterns": [
        "(create|build|add|implement).*?(component|page|ui|layout)",
        "(style|design).*?(component|page|ui)",
        "(frontend|client|ui).*?(component|feature|page)",
        "(form|input|button|modal)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "components/**/*.tsx",
        "src/components/**/*.tsx"
      ],
      "contentPatterns": [
        "import.*react",
        "className=",
        "tailwind"
      ]
    }
  },
  "tanstack-start-dev": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "TanStack Start (Vite-native React full-stack): server functions, file routing, loaders, middleware, SSR.",
    "promptTriggers": {
      "keywords": [
        "tanstack",
        "tanstack start",
        "createServerFn",
        "createFileRoute",
        "server function",
        "server fn",
        "inputValidator",
        "validator",
        "route loader",
        "beforeLoad",
        "validateSearch",
        "router",
        "route"
      ],
      "intentPatterns": [
        "(create|add|write).*?(server function|server fn|route|loader)",
        "(tanstack|react).*?(router|start)",
        "(file|nested).*?(route|routing)",
        "(redirect|notFound).*?(loader|route)",
        "(middleware).*?(server|route)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/routes/**/*.tsx",
        "src/routes/__root.tsx",
        "src/utils/*.functions.ts",
        "src/utils/*.server.ts",
        "src/router.tsx",
        "vite.config.ts",
        "app.config.ts"
      ],
      "contentPatterns": [
        "createFileRoute",
        "createServerFn",
        "@tanstack/react-router",
        "@tanstack/react-start",
        "Route\\.useLoaderData",
        "Route\\.useSearch",
        "Route\\.useParams",
        "useServerFn",
        "inputValidator",
        "createMiddleware"
      ]
    }
  },
  "task-management-dev": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Task-driven development workflow and PBI management",
    "promptTriggers": {
      "keywords": [
        "task",
        "pbi",
        "backlog",
        "workflow",
        "delivery",
        "planning",
        "dev docs",
        "sprint",
        "feature"
      ],
      "intentPatterns": [
        "(create|start|plan|implement).*?(task|pbi|feature)",
        "(update|check|show).*?(backlog|tasks|progress)",
        "(dev docs|development docs).*?(create|update|status)",
        "(mark|set).*?(done|complete|in.?progress)",
        "(what|which).*?(task|pbi).*?(next|current)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "docs/delivery/**/*",
        "dev/active/**/*",
        "**/backlog.md",
        "**/tasks.md",
        "**/*-plan.md",
        "**/*-context.md"
      ],
      "contentPatterns": [
        "Status.*?(Proposed|Agreed|InProgress|InReview|Done)",
        "## Status History",
        "## Implementation Plan",
        "\\[.*?\\]\\(.*?tasks\\.md\\)",
        "PBI-\\d+"
      ]
    }
  },
  "programmatic-seo": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Programmatic SEO strategy and implementation for data-driven, templated SEO pages at scale.",
    "promptTriggers": {
      "keywords": [
        "programmatic seo",
        "pseo",
        "template pages",
        "templated landing pages",
        "pages at scale",
        "directory pages",
        "location pages",
        "comparison pages",
        "integration pages",
        "data-driven pages",
        "keyword + city",
        "generate 100 pages",
        "many pages for seo"
      ],
      "intentPatterns": [
        "(create|build|generate|make|launch).*?(seo|landing).*?(pages|templates)",
        "(create|build|generate|make).*?(directory|location|comparison|integration).*?pages",
        "(programmatic|data.?driven|templated).*?(seo|pages|landing pages)",
        "(keyword|service|product).*?\\+.*?(city|location|industry|audience)",
        "(scale|mass|bulk).*?(seo|landing).*?pages",
        "(100|hundreds|thousands).*?(seo|landing|template).*?pages"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/sitemap*.ts",
        "**/sitemap*.js",
        "**/robots.ts",
        "**/robots.js",
        "**/seo/**/*.ts",
        "**/seo/**/*.tsx",
        "**/schema/**/*.ts",
        "**/content/**/*.md",
        "**/data/**/*.csv",
        "**/data/**/*.json"
      ],
      "contentPatterns": [
        "programmatic.?seo",
        "pSEO",
        "generateStaticParams",
        "getStaticPaths",
        "sitemap",
        "canonical",
        "noindex",
        "structured.?data",
        "schema\\.org"
      ]
    }
  },
  "code-simplifier": {
    "type": "quality",
    "enforcement": "suggest",
    "priority": "medium",
    "description": "Code simplification for clarity, consistency, and maintainability",
    "promptTriggers": {
      "keywords": [
        "simplify",
        "refactor",
        "clean up",
        "cleanup",
        "improve",
        "review",
        "readable",
        "clarity",
        "maintainable"
      ],
      "intentPatterns": [
        "(simplify|clean|improve|refactor).*?(code|function|component)",
        "(make|ensure).*?(readable|maintainable|clear)",
        "(code|review).*?(quality|standards)",
        "(reduce|remove).*?(complexity|nesting|duplication)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx"
      ],
      "contentPatterns": [
        "\\?.*?\\?.*?:",
        "if.*?{.*?if.*?{.*?if",
        "TODO.*?simplify",
        "TODO.*?refactor"
      ]
    }
  }
}
