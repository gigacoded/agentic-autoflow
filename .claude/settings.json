{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-submit.ts\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/typescript-check.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tsx .claude/*:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run:*)",
      "Bash(npx vitest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx convex:*)",
      "Read(.claude/**/*)",
      "Edit(.claude/**/*)",
      "Glob",
      "Grep"
    ],
    "deny": []
  }
}
