# Dev docs (active work)
dev/active/*
!dev/active/.gitkeep

# Test credentials (keep example, ignore actual)
dev/test-credentials.json

# Task workflow (if using)
docs/delivery/**/[0-9]*-*.md
!docs/delivery/**/*.template.md

# Node modules (if present)
node_modules/

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json.template
.idea/
*.swp
*.swo
*~

# Claude Code local settings (per-machine, not shared)
.claude/settings.local.json
CLAUDE.local.md

# Logs
*.log
logs/
__pycache__/
